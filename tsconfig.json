{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": [
    "dist",
    ".vercel",
    "node_modules",
    "public/pagefind",
    "public/frozen-issues",
    "pong_game",
    "buttondown-emails",
    "buttondown-oldold",
    "oneoffs"
  ],
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@*": ["./src/*"]
    }
  }
}
